engines:
    quake:
        enabled: true
        api_key: "your_quake_api_key_here"
        base_url: https://quake.360.net/api
        qps: 5
        timeout: 30
    zoomeye:
        enabled: true
        api_key: "your_zoomeye_api_key_here"
        base_url: https://api.zoomeye.org
        qps: 3
        timeout: 30
    hunter:
        enabled: true
        api_key: "your_hunter_api_key_here"
        base_url: https://hunter.qianxin.com
        qps: 5
        timeout: 30
    fofa:
        enabled: true
        api_key: "your_fofa_api_key_here"
        email: "your_fofa_email_here"
        base_url: https://fofa.info
        web_url: https://fofa.info
        qps: 3
        timeout: 30
        use_web_api: true
system:
    max_concurrent: 10
    cache_ttl: 3600
    cache_max_size: 1000
    cache_cleanup_interval: 300

# Web 截图与 CDP 配置
screenshot:
    enabled: true
    base_dir: ./screenshots
    chrome_path: ""
    # 浏览器代理，例如: http://127.0.0.1:7890 或 socks5://127.0.0.1:7891
    proxy_server: ""
    chrome_user_data_dir: ""
    chrome_profile_dir: "Default"
    chrome_remote_debug_url: "http://127.0.0.1:9222"
    headless: true
    timeout: 30
    window_width: 1365
    window_height: 768
    wait_time: 500
    auto_capture:
        enabled: false
        capture_search_results: true
        capture_targets: false

web:
    cors:
        allowed_origins:
            - http://localhost:8448
            - http://127.0.0.1:8448
        allowed_methods:
            - GET
            - POST
            - PUT
            - PATCH
            - DELETE
            - OPTIONS
        allowed_headers:
            - Content-Type
            - Authorization
            - X-Requested-With
            - X-WebSocket-Token
        exposed_headers: []
        allow_credentials: true
        max_age: 600
    rate_limit:
        enabled: true
        requests_per_window: 60
        window_seconds: 60
    request_limits:
        max_body_bytes: 10485760
        max_multipart_memory_bytes: 10485760

cache:
    # memory | redis
    backend: memory
    redis:
        addr: 127.0.0.1:6379
        password: ""
        db: 0
        prefix: unimap:
