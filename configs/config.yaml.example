engines:
    quake:
        enabled: true
        api_key: "your_quake_api_key_here"
        base_url: https://quake.360.net/api
        qps: 5
        timeout: 30
    zoomeye:
        enabled: true
        api_key: "your_zoomeye_api_key_here"
        base_url: https://api.zoomeye.org
        qps: 3
        timeout: 30
    hunter:
        enabled: true
        api_key: "your_hunter_api_key_here"
        base_url: https://hunter.qianxin.com
        qps: 5
        timeout: 30
    fofa:
        enabled: true
        api_key: "your_fofa_api_key_here"
        email: "your_fofa_email_here"
        base_url: https://fofa.info
        web_url: https://fofa.info
        qps: 3
        timeout: 30
        use_web_api: true
system:
    max_concurrent: 10

# Web 截图与 CDP 配置
screenshot:
    enabled: true
    base_dir: ./screenshots
    chrome_path: ""
    chrome_user_data_dir: ""
    chrome_profile_dir: "Default"
    chrome_remote_debug_url: "http://127.0.0.1:9222"
    headless: true
    timeout: 30
    window_width: 1365
    window_height: 768
    wait_time: 500
    auto_capture:
        enabled: false
        capture_search_results: true
        capture_targets: false
