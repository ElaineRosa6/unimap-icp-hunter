{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for UniMap metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "查询延迟 P50/P95/P99",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(unimap_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(unimap_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(unimap_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "alert": {
        "conditions": [
          {
            "evaluator": { "params": [30], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["B", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" }
          }
        ],
        "message": "Query P95 latency exceeds 30s",
        "frequency": "1m"
      }
    },
    {
      "id": 2,
      "title": "缓存命中率",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(unimap_cache_hits_total[5m])) / (sum(rate(unimap_cache_hits_total[5m])) + sum(rate(unimap_cache_misses_total[5m]))) * 100",
          "legendFormat": "Hit Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "alert": {
        "conditions": [
          {
            "evaluator": { "params": [50], "type": "lt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" }
          }
        ],
        "message": "Cache hit rate below 50%",
        "frequency": "5m"
      }
    },
    {
      "id": 3,
      "title": "截图成功率",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(unimap_screenshot_success_total[5m])) / (sum(rate(unimap_screenshot_success_total[5m])) + sum(rate(unimap_screenshot_failure_total[5m]))) * 100",
          "legendFormat": "Success Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "alert": {
        "conditions": [
          {
            "evaluator": { "params": [90], "type": "lt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" }
          }
        ],
        "message": "Screenshot success rate below 90%",
        "frequency": "5m"
      }
    },
    {
      "id": 4,
      "title": "篡改检测率",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(unimap_tamper_detected_total[5m]))",
          "legendFormat": "Detected",
          "refId": "A"
        },
        {
          "expr": "sum(rate(unimap_tamper_total[5m]))",
          "legendFormat": "Total Scans",
          "refId": "B"
        },
        {
          "expr": "sum(rate(unimap_tamper_detected_total[5m])) / sum(rate(unimap_tamper_total[5m])) * 100",
          "legendFormat": "Detection Rate %",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "节点健康度",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(unimap_distributed_nodes_online)",
          "legendFormat": "Online",
          "refId": "A"
        },
        {
          "expr": "sum(unimap_distributed_nodes_total)",
          "legendFormat": "Total",
          "refId": "B"
        },
        {
          "expr": "sum(unimap_distributed_nodes_online) / sum(unimap_distributed_nodes_total) * 100",
          "legendFormat": "Health %",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "alert": {
        "conditions": [
          {
            "evaluator": { "params": [80], "type": "lt" },
            "operator": { "type": "and" },
            "query": { "params": ["C", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" }
          }
        ],
        "message": "Node health below 80%",
        "frequency": "1m"
      }
    },
    {
      "id": 6,
      "title": "Goroutine 数",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "go_goroutines{job=\"unimap-web\"}",
          "legendFormat": "Goroutines",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "alert": {
        "conditions": [
          {
            "evaluator": { "params": [1000], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" }
          }
        ],
        "message": "Goroutine count exceeds 1000",
        "frequency": "5m"
      }
    },
    {
      "id": 7,
      "title": "内存使用",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "go_memstats_heap_alloc_bytes{job=\"unimap-web\"}",
          "legendFormat": "Heap Alloc",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{job=\"unimap-web\"}",
          "legendFormat": "Heap Inuse",
          "refId": "B"
        },
        {
          "expr": "go_memstats_sys_bytes{job=\"unimap-web\"}",
          "legendFormat": "Total Sys",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      },
      "alert": {
        "conditions": [
          {
            "evaluator": { "params": [858993459], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "avg" }
          }
        ],
        "message": "Heap allocation exceeds 800MB",
        "frequency": "5m"
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["unimap", "monitoring"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "UniMap Dashboard",
  "uid": "unimap-main",
  "version": 1,
  "weekStart": ""
}
