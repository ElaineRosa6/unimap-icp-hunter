# UniMap + ICP-Hunter 环境变量配置模板
# 复制此文件为 .env 并填入实际的 API Keys

# ==================== FOFA API 配置 ====================
# FOFA API Key (必需)
FOFA_API_KEY=your_fofa_api_key_here

# FOFA 邮箱 (必需)
FOFA_EMAIL=your_fofa_email@example.com


# ==================== Hunter API 配置 ====================
# Hunter API Key (必需)
HUNTER_API_KEY=your_hunter_api_key_here


# ==================== 邮件通知配置 (可选) ====================
# SMTP 服务器地址
EMAIL_SMTP_HOST=smtp.example.com

# SMTP 服务器端口 (通常 587 或 465)
EMAIL_SMTP_PORT=587

# 邮箱用户名
EMAIL_USERNAME=your_email@example.com

# 邮箱密码/授权码
EMAIL_PASSWORD=your_email_password

# 收件人邮箱 (多个用逗号分隔)
EMAIL_TO=admin@example.com,backup@example.com


# ==================== Webhook 通知配置 (可选) ====================
# Webhook URL (钉钉/企业微信/飞书等)
WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_token

# Webhook 类型: dingtalk / wechat / lark
WEBHOOK_TYPE=dingtalk


# ==================== 数据库配置 (可选) ====================
# 如果不使用 docker-compose 默认配置，可自定义
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=unimap_user
DB_PASSWORD=unimap_password
DB_NAME=unimap_icp_hunter


# ==================== Redis 配置 (可选) ====================
# 如果不使用 docker-compose 默认配置，可自定义
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0


# ==================== 存储配置 (可选) ====================
# MinIO/S3 配置 (用于截图存储)
STORAGE_TYPE=minio  # minio 或 s3
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=icp-screenshots
STORAGE_REGION=us-east-1


# ==================== 系统配置 (可选) ====================
# 应用环境
APP_ENV=prod

# 日志级别: debug / info / warn / error
LOG_LEVEL=info

# HTTP 超时时间 (秒)
HTTP_TIMEOUT=30

# ICP 检测超时时间 (秒)
ICP_TIMEOUT=10

# 最大并发数
MAX_CONCURRENCY=20

# 扫描策略 (逗号分隔)
SCAN_POLICIES=http_80,https_443,common_alt_ports

# Cron 调度时间 (标准 Cron 语法)
CRON_SCHEDULE=0 2 * * *

# 是否启用截图
ENABLE_SCREENSHOT=true

# ==================== 使用说明 ====================
# 1. 复制此文件为 .env
# 2. 填入实际的 API Keys
# 3. 运行: docker-compose up -d
# 4. 查看日志: docker-compose logs -f icp-scheduler

# ==================== 安全提示 ====================
# ⚠️  不要将 .env 文件提交到 Git
# ⚠️  定期轮换 API Keys
# ⚠️  使用强密码
# ⚠️  限制访问权限